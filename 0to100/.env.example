# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
KITE_API_KEY=REPLACE_ME
KITE_API_SECRET=REPLACE_ME
KITE_ACCESS_TOKEN=              # fill after OAuth login each morning

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_ME
# Budget-aware default: haiku-4-5 handles 780+ JSON decisions/market-day for <$2/mo.
# Upgrade to claude-sonnet-4-6 for higher accuracy (≈10× more expensive).
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── DeepSeek (pre-screener) ───────────────────────────────────────────────────
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=REPLACE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── NewsAPI (per-symbol headlines injected into Claude prompt) ────────────────
# Free tier: 100 req/day.  The cache TTL of 1800 s keeps daily usage ~20 req.
# Get key at: https://newsapi.org
NEWSAPI_KEY=REPLACE_ME

# ── Alpha Vantage (financials, fallback → yfinance when absent) ───────────────
ALPHA_VANTAGE_KEY=REPLACE_ME

# ── Portfolio / risk ──────────────────────────────────────────────────────────
SQ_INITIAL_EQUITY=1000000          # starting equity in INR (₹10 lakh)
SQ_PAPER_TRADING=true              # set to false ONLY for live Kite execution
SQ_TIMEZONE=Asia/Kolkata

# ── Scheduler cadences ────────────────────────────────────────────────────────
DECISION_INTERVAL_MIN=5            # Claude decision loop
SCREENER_INTERVAL_MIN=30           # DeepSeek pre-filter
ENSEMBLE_THRESHOLD_PCT=10          # re-prompt DeepSeek when Claude size_pct > this

# ── Paths ─────────────────────────────────────────────────────────────────────
SQ_DB_PATH=./data/sq_ai.db
SQ_LOG_PATH=./data/sq_ai.log
