# ── Zerodha Kite Connect ─────────────────────────────────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=             # filled after OAuth login each day

# ── LLM Credentials ──────────────────────────────────────────────────────────
# DeepSeek: first-pass signal generator (fast, data-driven)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# Anthropic Claude: senior analyst validation layer (optional — system degrades gracefully)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── News ─────────────────────────────────────────────────────────────────────
# Comma-separated RSS feed URLs
NEWS_RSS_FEEDS=https://feeds.feedburner.com/ndtvprofit-latest,https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms,https://www.moneycontrol.com/rss/MCtopnews.xml

# ── Trading Universe ─────────────────────────────────────────────────────────
UNIVERSE=RELIANCE,INFY,TCS,HDFCBANK,ICICIBANK,SBIN,AXISBANK,WIPRO,LT,BAJFINANCE

# ── Risk Limits ──────────────────────────────────────────────────────────────
MAX_CAPITAL_EXPOSURE=0.20          # max 20% of capital in any single stock
MAX_POSITION_SIZE_PCT=0.10         # max 10% of capital per trade
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.02            # kill switch triggers at 2% daily loss
MIN_SIGNAL_CONFIDENCE=0.60

# ── Engine ────────────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=300         # decision cycle every 5 minutes
EXCHANGE=NSE
PRODUCT_TYPE=MIS                   # MIS=intraday, CNC=delivery

# ── Backtest ──────────────────────────────────────────────────────────────────
BACKTEST_SLIPPAGE=0.0005           # 0.05%
BACKTEST_TRANSACTION_COST=0.001    # 0.10%
BACKTEST_INITIAL_CAPITAL=1000000   # 10 lakh INR

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
