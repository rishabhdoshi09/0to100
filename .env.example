# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=generated_each_morning_via_python_main.py_login

# ── DeepSeek (required for LLM signals, co-pilot, agents) ────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Anthropic Claude (optional — dual-LLM validation layer) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (optional — semantic news embeddings via Qdrant) ──────────────────
# Without this key, news search falls back to keyword matching (still works)
OPENAI_API_KEY=sk-...

# ── Trading Universe ──────────────────────────────────────────────────────────
UNIVERSE=RELIANCE,INFY,TCS,HDFCBANK,ICICIBANK

# ── Risk Limits ───────────────────────────────────────────────────────────────
MAX_CAPITAL_EXPOSURE=0.20
MAX_POSITION_SIZE_PCT=0.10
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.02
MIN_SIGNAL_CONFIDENCE=0.60

# ── Agent Supervisor (optional — runs parallel multi-agent cross-validation) ──
ENABLE_AGENT_SUPERVISOR=false

# ── Engine ────────────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=300
EXCHANGE=NSE
PRODUCT_TYPE=MIS
