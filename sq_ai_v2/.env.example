# ── Copy this file to .env and fill in real values ──────────────────────────

# ── Zerodha / Kite Connect ───────────────────────────────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token   # refresh daily via login flow

# ── Optional Data Sources ────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_key   # free tier at alphavantage.co
NEWSAPI_KEY=your_newsapi_key               # free tier at newsapi.org
FINNHUB_KEY=your_finnhub_key               # free tier at finnhub.io

# ── Databases ────────────────────────────────────────────────────────────────
QUESTDB_HOST=localhost
QUESTDB_PORT=9009          # ILP (line protocol) port
QUESTDB_HTTP_PORT=9000     # REST / query port

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sqai
POSTGRES_USER=sqai
POSTGRES_PASSWORD=sqai_secret

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Trading Universe ─────────────────────────────────────────────────────────
UNIVERSE=RELIANCE,INFY,TCS,HDFCBANK,ICICIBANK,WIPRO,AXISBANK,KOTAKBANK,LT,BAJFINANCE

# ── Risk ─────────────────────────────────────────────────────────────────────
MAX_CAPITAL_EXPOSURE=0.80
MAX_POSITION_SIZE_PCT=0.10
MAX_OPEN_POSITIONS=8
MAX_DAILY_LOSS_PCT=0.02
MIN_SIGNAL_CONFIDENCE=0.55
KELLY_FRACTION=0.25          # fractional Kelly multiplier
VOL_TARGET=0.15              # annual volatility target

# ── Backtest ─────────────────────────────────────────────────────────────────
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_SLIPPAGE=0.0005
BACKTEST_TRANSACTION_COST=0.001
BACKTEST_START_DATE=2020-01-01
BACKTEST_END_DATE=2023-12-31

# ── Models ───────────────────────────────────────────────────────────────────
MODEL_DIR=models/saved
WALK_FORWARD_TRAIN_YEARS=3
WALK_FORWARD_TEST_MONTHS=3

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── HuggingFace (FinBERT) ────────────────────────────────────────────────────
HF_MODEL_NAME=ProsusAI/finbert
HF_CACHE_DIR=.hf_cache
